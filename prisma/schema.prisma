generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "debian-openssl-3.0.x"]
  engineType    = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────
// USER & AUTHENTICATION (RBAC)
// ─────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN      // Full access to all features
  DOCTOR     // Can view, create, edit medical data
  PHARMACIST // Can view, create, edit drug data
  NURSE      // Can view and use calculators
  STUDENT    // Read-only access
  GUEST      // Limited read-only access
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String    // Hashed password
  role          UserRole  @default(GUEST)
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  image         String?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  favorites     Favorite[]
  auditLogs     AuditLog[]

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  userAgent    String?
  ipAddress    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────
// AUDIT LOGGING
// ─────────────────────────────────────────────────────────────────

enum AuditAction {
  LOGIN
  LOGOUT
  LOGIN_FAILED
  CREATE
  UPDATE
  DELETE
  VIEW
  EXPORT
  IMPORT
  PERMISSION_DENIED
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  action    AuditAction
  entity    String      // e.g., "Drug", "Herbal", "User"
  entityId  String?
  details   String?     @db.Text // JSON string with additional details
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────
// MEDICAL DATA MODELS
// ─────────────────────────────────────────────────────────────────

model Drug {
  id                  String                 @id @default(cuid())
  name                String
  genericName         String?
  brandNames          String?
  drugClass           String?
  category            String?                // Kategori: analgesic, antibiotic, etc.
  description         String?                // Deskripsi lengkap
  mechanism           String?
  route               String?
  halfLife            String?
  bioavailability     String?                // Bioavailabilitas
  proteinBinding      String?                // Ikatan protein
  metabolism          String?                // Metabolisme
  excretion           String?
  pregnancyCat        String?
  lactation           String?
  blackBoxWarning     String?                // Peringatan kotak hitam FDA
  regulatoryStatus    String?                // JSON: { BPOM, FDA, JKN }
  monitoringParameters String?               // Parameter monitoring
  counselingPoints    String?                // Edukasi pasien
  storage             String?
  notes               String?
  viewCount           Int                    @default(0)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  // Relations
  contraindications  DrugContraindication[]
  doses              DrugDose[]
  indications        DrugIndication[]
  interactions       DrugInteraction[]      @relation("DrugInteractions")
  interactingWith    DrugInteraction[]      @relation("InteractingDrug")
  favorites          Favorite[]             @relation("DrugFavorites")
  herbalInteractions HerbalInteraction[]    @relation("HerbalDrugInteractions")
  symptomMappings    SymptomDrugMapping[]

  @@index([name])
  @@index([genericName])
  @@index([drugClass])
  @@index([category])
}

model DrugDose {
  id              String   @id @default(cuid())
  drugId          String
  indication      String?
  adultDose       String
  pediatricDose   String?
  pediatricMinAge String?
  pediatricMaxAge String?
  maxDose         String?
  maxDoseUnit     String?
  frequency       String?
  duration        String?
  renalAdjust     String?
  hepaticAdjust   String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  drug            Drug     @relation(fields: [drugId], references: [id], onDelete: Cascade)
}

model DrugIndication {
  id            String   @id @default(cuid())
  drugId        String
  indication    String
  icdCode       String?
  priority      Int      @default(0)
  isFdaApproved Boolean  @default(false)    // Apakah disetujui FDA
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  drug          Drug     @relation(fields: [drugId], references: [id], onDelete: Cascade)
}

model DrugContraindication {
  id               String   @id @default(cuid())
  drugId           String
  contraindication String
  severity         String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  drug             Drug     @relation(fields: [drugId], references: [id], onDelete: Cascade)
}

model DrugInteraction {
  id                String   @id @default(cuid())
  drugId            String
  interactingDrugId String
  interactionType   String?
  effect            String?
  mechanism         String?
  management        String?
  evidenceLevel     String?               // Level bukti interaksi
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  drug              Drug     @relation("DrugInteractions", fields: [drugId], references: [id], onDelete: Cascade)
  interactingDrug   Drug     @relation("InteractingDrug", fields: [interactingDrugId], references: [id], onDelete: Cascade)
}

model Herbal {
  id               String              @id @default(cuid())
  name             String
  latinName        String?
  commonNames      String?
  localNames       String?             // Nama lokal Indonesia
  plantFamily      String?             // Famili tumbuhan
  category         String?             // Kategori: antiinflammatory, digestive, etc.
  plantPart        String?
  preparation      String?
  traditionalUse   String?
  description      String?             // Deskripsi lengkap
  safetyRating     String?
  pregnancySafety  String?
  lactationSafety  String?
  pediatricSafety  String?
  contraindications String?            // Kontraindikasi
  sideEffects      String?             // Efek samping
  regulatoryStatus String?
  references       String?
  notes            String?
  viewCount        Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  favorites        Favorite[]          @relation("HerbalFavorites")
  compounds        HerbalCompound[]
  indications      HerbalIndication[]
  interactions     HerbalInteraction[] @relation("HerbalInteractions")
  interactingWith  HerbalInteraction[] @relation("InteractingHerbal")

  @@index([name])
  @@index([latinName])
  @@index([category])
}

model HerbalCompound {
  id                String   @id @default(cuid())
  herbalId          String
  compoundName      String
  synonyms          String?             // Nama sinonim/singkatan
  concentration     String?
  pharmacology      String?
  biologicalActivity String?            // Aktivitas biologis
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  herbal            Herbal   @relation(fields: [herbalId], references: [id], onDelete: Cascade)
}

model HerbalIndication {
  id            String   @id @default(cuid())
  herbalId      String
  indication    String
  evidenceLevel String?
  studyType     String?
  dosage        String?
  duration      String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  herbal        Herbal   @relation(fields: [herbalId], references: [id], onDelete: Cascade)

  @@unique([herbalId, indication])
}

model HerbalInteraction {
  id                  String   @id @default(cuid())
  herbalId            String
  interactingDrugId   String?
  interactingHerbalId String?
  interactionType     String?
  effect              String?
  mechanism           String?
  management          String?
  evidenceLevel       String?             // Level bukti interaksi
  references          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  herbal              Herbal   @relation("HerbalInteractions", fields: [herbalId], references: [id], onDelete: Cascade)
  interactingHerbal   Herbal?  @relation("InteractingHerbal", fields: [interactingHerbalId], references: [id], onDelete: Cascade)
  interactingDrug     Drug?    @relation("HerbalDrugInteractions", fields: [interactingDrugId], references: [id], onDelete: SetNull)
}

model ClinicalNote {
  id          String     @id @default(cuid())
  title       String
  content     String
  category    String
  specialty   String?
  tags        String?
  source      String?
  author      String?
  version     Int        @default(1)
  isPublished Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  favorites   Favorite[] @relation("NoteFavorites")

  @@index([title])
  @@index([category])
}

model Symptom {
  id           String               @id @default(cuid())
  name         String
  category     String?
  description  String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  drugMappings SymptomDrugMapping[]

  @@index([name])
  @@index([category])
}

model SymptomDrugMapping {
  id          String   @id @default(cuid())
  symptomId   String
  drugId      String
  priority    Int      @default(0)
  isFirstLine Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  drug        Drug     @relation(fields: [drugId], references: [id], onDelete: Cascade)
  symptom     Symptom  @relation(fields: [symptomId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String        @id @default(cuid())
  userId    String
  itemType  String        // "drug" | "herbal" | "note"
  drugId    String?
  herbalId  String?
  noteId    String?
  notes     String?
  createdAt DateTime      @default(now())
  
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  drug      Drug?         @relation("DrugFavorites", fields: [drugId], references: [id], onDelete: Cascade)
  herbal    Herbal?       @relation("HerbalFavorites", fields: [herbalId], references: [id], onDelete: Cascade)
  note      ClinicalNote? @relation("NoteFavorites", fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType, drugId, herbalId, noteId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────
// Search & View Tracking
// ─────────────────────────────────────────────────────────────────

/// Log setiap query yang diketik user di search bar
model SearchLog {
  id        String   @id @default(cuid())
  query     String   // query sudah di-trim dan lowercase
  createdAt DateTime @default(now())

  @@index([query])
  @@index([createdAt])
}